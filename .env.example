# surakshak360-intelligence — environment variables
# Copy to .env for local dev. Railway injects these directly in prod.

SERVICE_NAME=intelligence
MODEL_VERSION=v1.0.0
ENV=development

HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

CORS_ORIGINS=["*"]

# Optional — leave unset to run on the built-in NetworkX in-memory graph.
# Set all three to switch to Neo4j (see app/services/graph_store.py).
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

EVIDENCE_STORAGE_DIR=/tmp/surakshak360_evidence
PUBLIC_BASE_URL=http://localhost:8000
